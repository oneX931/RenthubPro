@inject IConfiguration Config
@inject IHttpContextAccessor Http

@{
    var theme = Http.HttpContext?.Request.Cookies["theme"] == "dark" ? "dark" : "light";
}

<!DOCTYPE html>
<html lang="ru" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>RentHub Pro — аренда помещений</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          media="print" onload="this.media='all'" />
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    </noscript>

    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="RentHubPro.styles.css" />

    <script>
        (function () {
            try {
                var m = document.cookie.match(/(?:^|; )theme=([^;]+)/);
                var theme = m ? decodeURIComponent(m[1]) : (localStorage.getItem('theme') || 'light');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) { }
        })();
    </script>

    <HeadOutlet />
</head>
<body>
    <Routes />

    <script src="_framework/blazor.web.js"></script>
    <script src="lib/signalr/signalr.min.js"></script>
    <script src="js/theme.js"></script>
    <script src="js/chat.js"></script>
</body>
</html>
