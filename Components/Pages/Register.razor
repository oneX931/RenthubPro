@page "/register"
@layout EmptyLayout
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Регистрация — RentHub Pro</PageTitle>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="brand-lg">
            <span class="logo">R</span>
            <span>RentHub<span class="accent">Pro</span></span>
        </div>
        <h1>Регистрация</h1>
        <p class="auth-sub">Создайте аккаунт арендатора или арендодателя</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">@_error</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="HandleRegister" FormName="register">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Полное имя</label>
                <InputText class="form-control" @bind-Value="Input.FullName" placeholder="Иван Иванов" />
                <ValidationMessage For="() => Input.FullName" />
            </div>

            <div class="form-group">
                <label>Телефон (формат +375)</label>
                <InputText class="form-control" @bind-Value="Input.Phone" placeholder="+375291234567" autocomplete="tel" />
                <div class="form-hint">Допускаются коды операторов 25, 29, 33, 44.</div>
                <ValidationMessage For="() => Input.Phone" />
            </div>

            <div class="form-group">
                <label>E-mail (необязательно)</label>
                <InputText class="form-control" @bind-Value="Input.Email" placeholder="you@example.by" autocomplete="email" />
                <ValidationMessage For="() => Input.Email" />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Пароль</label>
                    <InputText type="password" class="form-control" @bind-Value="Input.Password"
                               autocomplete="new-password" />
                    <ValidationMessage For="() => Input.Password" />
                </div>
                <div class="form-group">
                    <label>Повторите пароль</label>
                    <InputText type="password" class="form-control" @bind-Value="Input.ConfirmPassword"
                               autocomplete="new-password" />
                    <ValidationMessage For="() => Input.ConfirmPassword" />
                </div>
            </div>

            <label style="display:block; font-weight:600; font-size:.88rem; margin-bottom:.35rem;">Тип аккаунта</label>
            <InputRadioGroup @bind-Value="Input.Role">
                <div class="role-picker" style="grid-template-columns:repeat(2,1fr);">
                    <label class="role-option">
                        <InputRadio Value="@Roles.Tenant" />
                        <span class="emoji">🔑</span>Арендатор
                    </label>
                    <label class="role-option">
                        <InputRadio Value="@Roles.Landlord" />
                        <span class="emoji">🏢</span>Арендодатель
                    </label>
                </div>
            </InputRadioGroup>

            <button type="submit" class="btn btn-primary btn-block">Зарегистрироваться</button>
        </EditForm>

        <p class="auth-switch">Уже есть аккаунт? <a href="/login">Войти</a></p>
    </div>
</div>

@code {
    [SupplyParameterFromForm] private RegisterModel Input { get; set; } = default!;

    private string? _error;

    protected override void OnInitialized() => Input ??= new();

    private async Task HandleRegister()
    {
        _error = null;

        if (Input.Password != Input.ConfirmPassword)
        {
            _error = "Пароли не совпадают.";
            return;
        }

        if (Input.Role != Roles.Tenant && Input.Role != Roles.Landlord)
        {
            _error = "Недопустимый тип аккаунта.";
            return;
        }

        var phone = PhoneNumberValidator.Normalize(Input.Phone);
        if (!PhoneNumberValidator.IsValid(phone))
        {
            _error = "Телефон должен быть в формате +375 (например, +375291234567).";
            return;
        }

        if (await UserManager.Users.AnyAsync(u => u.PhoneNumber == phone))
        {
            _error = "Пользователь с таким номером телефона уже зарегистрирован.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = phone,
            PhoneNumber = phone,
            FullName = string.IsNullOrWhiteSpace(Input.FullName) ? phone : Input.FullName.Trim(),
            Email = string.IsNullOrWhiteSpace(Input.Email) ? null : Input.Email.Trim(),
            EmailConfirmed = true,
            Theme = AppTheme.Light
        };

        var created = await UserManager.CreateAsync(user, Input.Password);
        if (!created.Succeeded)
        {
            _error = string.Join(" ", created.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, Input.Role);
        await SignInManager.SignInAsync(user, isPersistent: true);

        Navigation.NavigateTo("/", forceLoad: true);
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Укажите имя")]
        public string FullName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Укажите телефон")]
        public string Phone { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некорректный e-mail")]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите пароль")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Минимум 6 символов")]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Повторите пароль")]
        public string ConfirmPassword { get; set; } = string.Empty;

        public string Role { get; set; } = Roles.Tenant;
    }
}
