@page "/Error"
@layout EmptyLayout

<PageTitle>Ошибка — RentHub Pro</PageTitle>

<div class="auth-wrap">
    <div class="auth-card" style="text-align:center;">
        <div class="brand-lg">
            <span class="logo">R</span>
            <span>RentHub<span class="accent">Pro</span></span>
        </div>
        <div style="font-size:3rem; margin:.5rem 0;">⚠️</div>
        <h1>Что-то пошло не так</h1>
        <p class="auth-sub">Произошла непредвиденная ошибка при обработке запроса.</p>
        <a class="btn btn-primary btn-block" href="/">Вернуться на главную</a>
    </div>
</div>
