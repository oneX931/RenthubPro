@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized>
        <div class="app-shell">
            <NavMenu />
            <div class="main-area">
                <div class="topbar">
                    <div class="topbar-title">RentHub Pro</div>
                    <div class="toolbar">
                        <button class="icon-btn" type="button" title="Сменить тему оформления"
                                onclick="rentHubTheme.toggle()">🌓</button>
                        <a class="btn btn-ghost btn-sm" href="/logout">Выйти</a>
                    </div>
                </div>
                <div class="content">
                    @Body
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="public-shell">
            <header class="public-topbar">
                <a href="/" class="brand">
                    <span class="logo">R</span>
                    <span>RentHub<span class="accent">Pro</span></span>
                </a>
                <div class="toolbar">
                    <button class="icon-btn" type="button" title="Сменить тему оформления"
                            onclick="rentHubTheme.toggle()">🌓</button>
                    <a class="btn btn-outline btn-sm" href="/login">Вход</a>
                    <a class="btn btn-primary btn-sm" href="/register">Регистрация</a>
                </div>
            </header>
            <div class="content">
                @Body
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
